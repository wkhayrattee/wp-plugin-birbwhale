# Composer: vendor/ is generated build output — not tracked.
#   dev:     composer dump-autoload --optimize     (no deps to fetch — instant)
#   release: composer install --no-dev --optimize-autoloader
#            (the GitHub Actions release workflow runs this and bundles vendor in the zip)
/includes/vendor/
composer.lock
